# ===========================================
# EV Range Tools - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# cp .env.local.example .env.local

# -------------------------------------------
# Site URL
# -------------------------------------------
# Production: https://www.evrangetools.com
NEXT_PUBLIC_SITE_URL=https://www.evrangetools.com

# -------------------------------------------
# Supabase
# -------------------------------------------
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — NEVER expose to the client. Used in Edge Functions only.
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------------------------
# Mapbox
# -------------------------------------------
# Get from: https://account.mapbox.com/access-tokens/
# Public token for maps, isochrone, directions, geocoding
NEXT_PUBLIC_MAPBOX_TOKEN=

# -------------------------------------------
# APIs (server-side only — never expose to client)
# -------------------------------------------
# NREL Alternative Fuel Stations API
# Get from: https://developer.nrel.gov/signup/
NREL_API_KEY=

# OpenChargeMap API (global charging stations)
# Get from: https://openchargemap.org/site/develop/api
OPENCHARGE_API_KEY=

# OpenWeather API (temperature-adjusted range)
# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# API Ninjas Electric Vehicle API (supplemental EV data)
# Get from: https://api-ninjas.com/api/electricvehicle
API_NINJAS_KEY=

# Anthropic Claude API (AI Range Advisor)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# -------------------------------------------
# Vercel
# -------------------------------------------
# Automatically set by Vercel during deployment
VERCEL_URL=

# -------------------------------------------
# Analytics
# -------------------------------------------
# Plausible Analytics domain (privacy-friendly, no cookie banner)
# Get from: https://plausible.io/
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
